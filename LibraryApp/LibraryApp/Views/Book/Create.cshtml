@model Book

@{
    ViewData["Title"] = "Add Book";
}

<div class="form-card">
    <h1>Add New Book</h1>

    <form asp-action="Create" method="post">
        <div class="form-group">
            <label asp-for="Title">Title</label>
            <input asp-for="Title" placeholder="e.g. The Pragmatic Programmer" />
            <span asp-validation-for="Title" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Author">Author</label>
            <input asp-for="Author" placeholder="e.g. Andrew Hunt" />
            <span asp-validation-for="Author" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price">Price (₹)</label>
            <input asp-for="Price" type="number" step="0.01" placeholder="e.g. 499.00" />
            <span asp-validation-for="Price" class="error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Book</button>
            <a href="/Book/List" class="btn">Cancel</a>
        </div>
    </form>
</div>
