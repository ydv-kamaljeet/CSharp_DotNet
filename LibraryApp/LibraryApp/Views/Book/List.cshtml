@model IEnumerable<Book>

@{
    ViewData["Title"] = "All Books";
}

<div class="page-header">
    <h1>All Books</h1>
    <a href="/Book/Create" class="btn btn-primary">+ Add New Book</a>
</div>

@if (!Model.Any())
{
    <p class="empty-msg">No books found. Add one to get started.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Author</th>
                <th>Price (₹)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.BookId</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Price.ToString("0.00")</td>
                    <td class="actions">
                        <a href="/Book/Details/@book.BookId">View</a>
                        <a href="/Book/Delete/@book.BookId" class="danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
